{
  "name": "robot-viewer",
  "version": "1.2.1",
  "description": "Web-based robot model viewer supporting URDF, MJCF, and USD formats",
  "main": "electron/main.cjs",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"vite\" \"wait-on tcp:3000 && cross-env ELECTRON_START_URL=http://127.0.0.1:3000 electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "build:electron": "vite build && electron-builder",
    "dist:win": "cross-env ELECTRON_BUILDER_BINARIES_MIRROR=\"https://npmmirror.com/mirrors/electron-builder-binaries/\" vite build && electron-builder --win portable",
    "dist:win:dir": "vite build && electron-builder --win dir",
    "dist:linux": "vite build && electron-builder --linux"
  },
  "keywords": [
    "robot",
    "urdf",
    "xacro",
    "mjcf",
    "usd",
    "three.js",
    "viewer"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@babel/runtime": "^7.23.0",
    "@codemirror/autocomplete": "^6.12.0",
    "@codemirror/commands": "^6.3.3",
    "@codemirror/lang-xml": "^6.0.2",
    "@codemirror/search": "^6.5.5",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.23.0",
    "@uiw/codemirror-theme-dracula": "^4.21.21",
    "@uiw/codemirror-theme-github": "^4.21.21",
    "@uiw/codemirror-theme-vscode": "^4.21.21",
    "codemirror": "^6.0.1",
    "d3": "^7.9.0",
    "mujoco-js": "^0.0.7",
    "three": "^0.163.0",
    "urdf-loader": "^0.12.5",
    "xacro-parser": "^0.3.11"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^35.0.3",
    "electron-builder": "^25.1.8",
    "terser": "^5.26.0",
    "vite": "^4.5.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.robotsfan.robotviewer",
    "productName": "Robot Viewer",
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icons/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "signAndEditExecutable": false,
      "icon": "public/icon.ico",
      "target": [
        "portable"
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Science",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    }
  }
}

