{
  "name": "robot-viewer",
  "version": "1.2.1",
  "description": "Web-based robot model viewer supporting URDF, MJCF, and USD formats",
  "main": "index.html",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "android:add": "npx cap add android",
    "android:sync": "pnpm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:apk:debug": "pnpm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:apk:release": "pnpm run android:sync && cd android && gradlew.bat assembleRelease"
  },
  "keywords": [
    "robot",
    "urdf",
    "xacro",
    "mjcf",
    "usd",
    "three.js",
    "viewer"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@babel/runtime": "^7.23.0",
    "@capacitor/android": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@codemirror/autocomplete": "^6.12.0",
    "@codemirror/commands": "^6.3.3",
    "@codemirror/lang-xml": "^6.0.2",
    "@codemirror/search": "^6.5.5",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.23.0",
    "@uiw/codemirror-theme-dracula": "^4.21.21",
    "@uiw/codemirror-theme-github": "^4.21.21",
    "@uiw/codemirror-theme-vscode": "^4.21.21",
    "codemirror": "^6.0.1",
    "d3": "^7.9.0",
    "mujoco-js": "^0.0.7",
    "three": "^0.163.0",
    "urdf-loader": "^0.12.5",
    "xacro-parser": "^0.3.11"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "concurrently": "9.2.1",
    "cross-env": "7.0.3",
    "electron": "35.7.5",
    "electron-builder": "25.1.8",
    "terser": "^5.26.0",
    "vite": "^4.5.0",
    "wait-on": "8.0.5"
  }
}
